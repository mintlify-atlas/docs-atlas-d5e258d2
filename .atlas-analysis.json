  "projectType": "saas",
  "projectName": "BidCo",
  "projectDescription": "BidCo is a full-stack web platform for managing normal and blind auctions, as well as raffles, built with Angular, Spring Boot, and PostgreSQL.",
  "theme": "maple",
  "primaryColor": "#1A6BCC",
  "lightColor": "#3B8FE8",
